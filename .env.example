# CanaData Configuration
# Weedmaps API Base URL
WEEDMAPS_BASE_URL=https://api-g.weedmaps.com/discovery/v1/listings
PAGE_SIZE=100

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Concurrent Processing Configuration
MAX_WORKERS=10
RATE_LIMIT=1.0
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1.0

# Caching Configuration
CACHE_ENABLED=true
CACHE_TTL=3600
MEMORY_CACHE_SIZE=2000
DISK_CACHE_TTL=21600
CACHE_DIR=cache
ENABLE_DISK_CACHE=true

# Data Processing Configuration
OPTIMIZE_PROCESSING=true
PROCESSING_MAX_WORKERS=4
CHUNK_SIZE=1000
STREAMING_THRESHOLD=10000

# Alternative Sources
# Obtain from https://apify.com/console
APIFY_TOKEN=your_apify_token_here
# Obtain from CannMenus Pro account
CANNMENUS_API_TOKEN=your_cannmenus_token_here

# Pluggable Data Sources (data_sources/ package)
# The DataSourceManager auto-registers adapters that have valid credentials.
# Add tokens for any new adapters you create here, e.g.:
# EXAMPLE_API_TOKEN=your_token_here
# EXAMPLE_SCRAPER_TOKEN=your_token_here
